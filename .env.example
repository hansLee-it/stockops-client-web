# StockOps Client Web Environment Variables
# Public-safe template only. Copy to .env.local locally.
# IMPORTANT: VITE_* values are bundled into browser JavaScript. Do not put real secrets here.

VITE_API_BASE_URL=/api
VITE_DEV_PORT=5173
VITE_PREVIEW_PORT=4173

# AI chat, session-only storage key. Not a secret.
VITE_CHAT_SESSION_STORAGE_KEY=stockops.client.chat.messages
VITE_CHAT_CONTEXT_MESSAGE_LIMIT=12
